      "source": [
        "!pip install torch torchvision torchaudio\n",
        "!pip install transformers datasets accelerate\n",
        "!pip install nltk bert-score pandas\n",
        "\n",
        "import pandas as pd\n",
        "import torch\n",
        "import time\n",
        "from datasets import Dataset as HFDataset\n",
        "from transformers import (\n",
        "    AutoTokenizer,\n",
        "    AutoModelForSeq2SeqLM,\n",
        "    DataCollatorForSeq2Seq,\n",
        "    Seq2SeqTrainingArguments,\n",
        "    Seq2SeqTrainer\n",
        ")\n",
        "\n",
        "from nltk.translate.bleu_score import corpus_bleu\n",
        "from bert_score import score as bert_score\n",
        "\n",
        "from transformers import Seq2SeqTrainingArguments\n",
        "import transformers\n",
        "\n",
        "# Detect version\n",
        "version = transformers.__version__\n",
        "print(\"Transformers version:\", version)\n",
        "\n",
        "# --- Define Training Arguments ---\n",
        "if hasattr(Seq2SeqTrainingArguments, \"__init__\") and \"evaluation_strategy\" in Seq2SeqTrainingArguments.__init__.__code__.co_varnames:\n",
        "    # Modern versions (>=4.0) support evaluation_strategy\n",
        "    training_args = Seq2SeqTrainingArguments(\n",
        "        output_dir=\"./results\",\n",
        "        evaluation_strategy=\"epoch\",\n",
        "        save_strategy=\"epoch\",\n",
        "        logging_strategy=\"epoch\",\n",
        "        per_device_train_batch_size=16,\n",
        "        per_device_eval_batch_size=16,\n",
        "        num_train_epochs=3,\n",
        "        predict_with_generate=True,\n",
        "        fp16=True\n",
        "    )\n",
        "else:\n",
        "# --- 4. Define Fine-Tuning Arguments ---\n",
        "    training_args = Seq2SeqTrainingArguments(\n",
        "        output_dir=\"./results\",\n",
        "        eval_strategy=\"epoch\",               # FIXED: Changed from evaluation_strategy to eval_strategy\n",
        "        learning_rate=3e-5,\n",
        "        per_device_train_batch_size=8,\n",
        "        per_device_eval_batch_size=8,\n",
        "        weight_decay=0.01,\n",
        "        save_total_limit=1,\n",
        "        num_train_epochs=3,\n",
        "        predict_with_generate=True,\n",
        "        fp16=torch.cuda.is_available(),\n",
        "        logging_steps=100,\n",
        "        report_to=\"none\"\n",
        "    )\n",
        "\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "\n",
        "# --- 1. Data Loading & Pairing ---\n",
        "train_sa = pd.read_csv(\"/home/train_sa_10000.csv\")\n",
        "train_en = pd.read_csv(\"/home/train_en_10000.csv\")\n",
        "dev_sa   = pd.read_csv(\"/home/dev_sa_1000.csv\")\n",
        "dev_en   = pd.read_csv(\"/home/dev_en_1000.csv\")\n",
        "test_sa  = pd.read_csv(\"/home/test_sa_1000.csv\")\n",
        "\n",
        "train_pairs = pd.merge(train_sa, train_en, on=\"Source_id\").dropna()\n",
        "dev_pairs   = pd.merge(dev_sa, dev_en, on=\"Source_id\").dropna()\n",
        "\n",
        "# --- 2. Initialize Pre-trained Tokenizer & Model ---\n",
        "# Using mBART-50 which supports many-to-many multilingual translation tasks\n",
        "MODEL_NAME = \"facebook/mbart-large-50\"\n",
        "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
        "model = AutoModelForSeq2SeqLM.from_pretrained(MODEL_NAME).to(device)\n",
        "\n",
        "# Set source and target language configurations for the tokenizer\n",
        "# Adjust language codes if working with specific variants (e.g., hi_IN, sa_IN, etc.)\n",
        "tokenizer.src_lang = \"hi_IN\"\n",
        "tokenizer.tgt_lang = \"en_XX\"\n",
        "\n",
        "# --- 3. Data Processing Pipeline ---\n",
        "def preprocess_function(examples):\n",
        "    inputs = [ex for ex in examples[\"Sentence_sa\"]]\n",
        "    targets = [ex for ex in examples[\"Sentence_en\"]]\n",
        "\n",
        "    # Pass both inputs and targets to the tokenizer at once\n",
        "    model_inputs = tokenizer(\n",
        "        inputs,\n",
        "        text_target=targets,\n",
        "        max_length=128,\n",
        "        truncation=True\n",
        "    )\n",
        "\n",
        "    return model_inputs\n",
        "# Convert Pandas DataFrames into Hugging Face Dataset objects\n",
        "train_dataset = HFDataset.from_pandas(train_pairs)\n",
        "dev_dataset = HFDataset.from_pandas(dev_pairs)\n",
        "\n",
        "# Tokenize datasets\n",
        "train_tokenized = train_dataset.map(preprocess_function, batched=True, remove_columns=train_dataset.column_names)\n",
        "dev_tokenized = dev_dataset.map(preprocess_function, batched=True, remove_columns=dev_dataset.column_names)\n",
        "\n",
        "# Data Collator handles dynamic batch padding automatically\n",
        "data_collator = DataCollatorForSeq2Seq(tokenizer, model=model)\n",
        "\n",
        "# --- 4. Define Fine-Tuning Arguments ---\n",
        "training_args = Seq2SeqTrainingArguments(\n",
        "    output_dir=\"./results\",\n",
        "    eval_strategy=\"epoch\",\n",
        "    learning_rate=3e-5,                  # Transformers use a lower learning rate for fine-tuning\n",
        "    per_device_train_batch_size=8,       # Reduced batch size due to massive model memory profile\n",
        "    per_device_eval_batch_size=8,\n",
        "    weight_decay=0.01,\n",
        "    save_total_limit=1,\n",
        "    num_train_epochs=3,                  # Fine-tuning large models typically requires 3-5 epochs\n",
        "    predict_with_generate=True,          # Uses evaluation decoding generation loops\n",
        "    fp16=torch.cuda.is_available(),      # Uses mixed-precision tracking to accelerate speed if on GPU\n",
        "    logging_steps=100,\n",
        "    report_to=\"none\"\n",
        ")\n",
        "\n",
        "# Initialize the Trainer interface wrapper\n",
        "trainer = Seq2SeqTrainer(\n",
        "    model=model,\n",
        "    args=training_args,\n",
        "    train_dataset=train_tokenized,\n",
        "    eval_dataset=dev_tokenized,\n",
        "    processing_class=tokenizer,\n",
        "    data_collator=data_collator,\n",
        ")\n",
        "\n",
        "# --- 5. Run Fine-Tuning ---\n",
        "print(\"Starting fine-tuning process...\")\n",
        "trainer.train()\n",
        "\n",
        "# --- 6. Metrics & Evaluation Handling ---\n",
        "def evaluate_metrics(model, df_pairs):\n",
        "    model.eval()\n",
        "    refs, hyps = [], []\n",
        "\n",
        "    print(\"Running batch evaluations...\")\n",
        "    for idx, row in df_pairs.iterrows():\n",
        "        inputs = tokenizer(row[\"Sentence_sa\"], return_tensors=\"pt\", truncation=True).to(device)\n",
        "\n",
        "        with torch.no_grad():\n",
        "            generated_tokens = model.generate(\n",
        "                **inputs,\n",
        "                forced_bos_token_id=tokenizer.lang_code_to_id[\"en_XX\"],\n",
        "                max_length=128,\n",
        "                num_beams=5\n",
        "            )\n",
        "\n",
        "        pred_sentence = tokenizer.decode(generated_tokens[0], skip_special_tokens=True)\n",
        "        ref_sentence = row[\"Sentence_en\"]\n",
        "\n",
        "        hyps.append(pred_sentence)\n",
        "        refs.append(ref_sentence)\n",
        "\n",
        "    # BLEU Format Parsing\n",
        "    bleu_hyps = [h.split() for h in hyps]\n",
        "    bleu_refs = [[r.split()] for r in refs]\n",
        "    bleu_score = corpus_bleu(bleu_refs, bleu_hyps)\n",
        "\n",
        "    # BERTScore Calculations\n",
        "    P, R, F1 = bert_score(hyps, refs, lang=\"en\", rescale_with_baseline=True)\n",
        "    return bleu_score, F1.mean().item()\n",
        "\n",
        "dev_bleu, dev_bert = evaluate_metrics(model, dev_pairs)\n",
        "print(f\"Fine-Tuned BLEU (Dev): {dev_bleu:.4f}\")\n",
        "print(f\"Fine-Tuned BERTScore F1 (Dev): {dev_bert:.4f}\")\n",
        "\n",
        "# --- 7. Test Inference and Submission Export ---\n",
        "def generate_submission(model, test_df):\n",
        "    model.eval()\n",
        "    preds = []\n",
        "    start_time = time.time()\n",
        "\n",
        "    print(\"Generating translations for test set...\")\n",
        "    for idx, row in test_df.iterrows():\n",
        "        inputs = tokenizer(str(row[\"Sentence_sa\"]), return_tensors=\"pt\", truncation=True).to(device)\n",
        "\n",
        "        with torch.no_grad():\n",
        "            generated_tokens = model.generate(\n",
        "                **inputs,\n",
        "                forced_bos_token_id=tokenizer.lang_code_to_id[\"en_XX\"],\n",
        "                max_length=128,\n",
        "                num_beams=5\n",
        "            )\n",
        "\n",
        "        pred_sentence = tokenizer.decode(generated_tokens[0], skip_special_tokens=True)\n",
        "        preds.append((row[\"Source_id\"], pred_sentence, row[\"Sentence_sa\"]))\n",
        "\n",
        "    total_time = time.time() - start_time\n",
        "    num_params = sum(p.numel() for p in model.parameters())\n",
        "    return preds, total_time, num_params\n",
        "\n",
        "preds, inf_time, total_parameters = generate_submission(model, test_sa)\n",
        "print(f\"Inference Running Time: {inf_time:.2f} seconds\")\n",
        "print(f\"Total Model Parameters: {total_parameters}\")\n",
        "\n",
        "# Output submission artifact dataframe\n",
        "submission = pd.DataFrame(preds, columns=[\"Source_id\", \"Sentence_en\", \"Sentence_sa\"])\n",
        "submission.to_csv(\"submission.csv\", index=False, encoding=\"utf-8\")\n",
        "print(\"Submission processing complete! File saved as submission.csv\")"
      ]
    }
